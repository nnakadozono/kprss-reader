# Copy this file to .env and fill in local values.
# Do not commit .env.

# Path to the source SQLite database. Prefer a path relative to this repository.
KPDB=../kprss/path-to-source.db

# Optional: source article table name. If omitted, the generator uses KPSHORT or
# tries to infer the table from required columns.
KPSHORT=your_article_table
# KPRSS_READER_ARTICLE_TABLE=your_article_table

# Optional: source image/asset table name. If omitted, the generator tries to
# infer the table from required columns.
# KPRSS_READER_ASSET_TABLE=your_asset_table

# Optional: number of latest article dates to generate.
# KPRSS_READER_DAYS=10

# Hosting: used by scripts/deploy_site.sh.
# KPRSS_READER_SITE_BUCKET=your-existing-kprss-bucket
# KPRSS_READER_SITE_PREFIX=reader/site
# KPRSS_READER_CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Optional: AWS CLI settings for deployment commands.
# AWS_PROFILE=your-profile
# AWS_REGION=ap-northeast-1
